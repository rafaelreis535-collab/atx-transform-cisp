# AI Cockpit Modernization API Configuration
# Copy this file to .env and fill in your actual values

# Required: API Base URL
MODERNIZATION_API_URL=https://aic-modernization-api.compass.uol/

# Required: API Authentication Key
# Get this from your AI Cockpit Modernization account
MODERNIZATION_API_KEY=your-api-key-here

# Required: Organization ID
MODERNIZATION_ORG_ID=686

# Required: Project Name
# This will be used as the project name in the API
# If not set, will derive from PROJECT_PATH (e.g., "banking-example" from "./banking-example")
MODERNIZATION_PROJECT_NAME=Banking Java Full Documentation

# Optional: LLM Provider
# Options: anthropic, openai, awsbedrockai
# MODERNIZATION_LLM_PROVIDER=anthropic

# Optional: LLM Model
# Examples:
#   - claude-3-5-sonnet
#   - us.anthropic.claude-haiku-4-5-20251001-v1:0
#   - gpt-4
# MODERNIZATION_LLM_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Optional: Output Language
# Options: en_US, pt_BR, es_ES
MODERNIZATION_OUTPUT_LANGUAGE=en_US

# Optional: Poll Interval (milliseconds)
# How often to check task status
MODERNIZATION_POLL_INTERVAL_MS=30000